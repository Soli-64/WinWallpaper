{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "switch-bar",
  "description": "Capability for the switch-bar controller window",
  "windows": ["switch-bar"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "wallpaper:default",
    "allow-get-wallpapers",
    "allow-get-default-wallpaper",
    "allow-get-widgets",
    "allow-get-monitors",
    "allow-get-monitor-wallpaper",
    "allow-set-monitor-wallpaper",
    "allow-get-monitor-widgets",
    "allow-set-monitor-widgets",
    "allow-get-active-setup",
    "allow-set-active-setup",
    "allow-refresh-app",
    "allow-get-custom-mode",
    "allow-set-custom-mode",
    "allow-get-setups",
    "global-shortcut:default"
  ]
}
